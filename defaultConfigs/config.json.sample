{
  "files": {
    "sourceDirectoryPath": "./data/src",
    "destinationDirectoryPath": "./data/dst"
  },
  "socks": {
    "ip": "127.0.0.1",
    "port": 1080,
    "user": "socks-user",
    "password": "socks-password"
  },
  "vpnServers": {
    "default": {
      "naiveproxy": {
        "useQuic": false
      },
      "mieru": {
        "ip": "203.0.113.10"
      }
    },
    "servers": {
      "server-1": {
        "name": "Основной VPN",
        "naiveproxy": {
          "ip": "203.0.113.10",
          "useQuic": false
        },
        "mieru": {
          "ip": "203.0.113.10"
        }
      },
      "server-2": {
        "name": "Резервный VPN",
        "naiveproxy": {
          "ip": "203.0.113.11",
          "useQuic": true
        },
        "mieru": {
          "ip": "203.0.113.11"
        }
      },
      "common": {
        "name": "Общие данные"
      }
    }
  },
  "webServer": {
    "enabled": true,
    "baseUrl": "https://configs.example.com",
    "users": [
      {
        "userName": "user1",
        "password": "change-me"
      },
      {
        "userName": "user2",
        "password": "change-me"
      }
    ],
    "sshAuth": {
      "enabled": false,
      "host": "example.com",
      "user": "deploy",
      "htpasswdPath": "/etc/nginx/.htpasswd"
    },
    "rsync": {
      "enabled": false,
      "host": "example.com",
      "destination": "/var/www/html/config-site/",
      "user": "deploy"
    }
  }
}